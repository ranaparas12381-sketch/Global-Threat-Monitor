{
  "name": "global-threat-monitor",
  "version": "2.0.0",
  "description": "Real-Time Global DDoS Threat Intelligence Dashboard — visualizes cyber attacks on a 3D globe using Globe.gl and Cloudflare Radar.",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "lint":    "eslint . --ext .js",
    "test":    "jest --coverage",
    "docker:build": "docker build -t global-threat-monitor .",
    "docker:run":   "docker run -p 3000:3000 --env-file .env global-threat-monitor"
  },
  "keywords": [
    "ddos",
    "cybersecurity",
    "threat-intelligence",
    "visualization",
    "globe",
    "cloudflare-radar"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  },
  "dependencies": {
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":             "^7.1.0",
    "morgan":             "^1.10.0"
  },
  "devDependencies": {
    "eslint":             "^8.57.0",
    "jest":               "^29.7.0",
    "nodemon":            "^3.1.4",
    "supertest":          "^7.0.0"
  }
}
