# ============================================================
# Global Threat Monitor — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Cloudflare Radar API ──────────────────────────────────────
# Obtain your token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account > Cloudflare Radar > Read
# Leave empty to run in simulation-only mode.
CLOUDFLARE_TOKEN=

# ── CORS ──────────────────────────────────────────────────────
# Restrict origins in production, e.g.: https://yourdomain.com
ALLOWED_ORIGIN=*
